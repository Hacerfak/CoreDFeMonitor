<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CoreDFeMonitor.UI.ViewModels"
    xmlns:dto="using:CoreDFeMonitor.Application.Features.Documentos.Dtos"
    xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    x:Class="CoreDFeMonitor.UI.Views.DashboardView"
    x:DataType="vm:DashboardViewModel">

    <Grid ColumnDefinitions="260, *">
        <Border Grid.Column="0" Background="#2C3E50" Padding="0,20">
            <StackPanel Spacing="10">
                <TextBlock Text="DFe Monitor" Foreground="White" FontSize="24" FontWeight="Bold"
                    Margin="25,0,20,35" />

                <Button Background="#34495E" Foreground="White" HorizontalAlignment="Stretch"
                    Padding="25,18" CornerRadius="0">
                    <StackPanel Orientation="Horizontal" Spacing="18">
                        <icons:MaterialIcon Kind="ViewDashboard" Width="22" Height="22"
                            Foreground="White" />
                        <TextBlock Text="Visão Geral" VerticalAlignment="Center" FontSize="16" />
                    </StackPanel>
                </Button>

                <Button Background="Transparent" Foreground="#BDC3C7" HorizontalAlignment="Stretch"
                    Padding="25,18" CornerRadius="0" Command="{Binding NavegarDocumentosCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="18">
                        <icons:MaterialIcon Kind="FileDocumentMultiple" Width="22" Height="22"
                            Foreground="#BDC3C7" />
                        <TextBlock Text="Documentos" VerticalAlignment="Center" FontSize="16" />
                    </StackPanel>
                </Button>

                <Button Background="Transparent" Foreground="#BDC3C7" HorizontalAlignment="Stretch"
                    Padding="25,18" CornerRadius="0" Command="{Binding AbrirConfiguracoesCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="18">
                        <icons:MaterialIcon Kind="Cog" Width="22" Height="22" Foreground="#BDC3C7" />
                        <TextBlock Text="Configurações" VerticalAlignment="Center" FontSize="16" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="1" Background="#F5F5F5">
            <StackPanel Margin="30" Spacing="25">

                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Dashboard" FontSize="32" FontWeight="SemiBold"
                            Foreground="#333333" />
                        <TextBlock Text="Volumes e estatísticas de monitoramento da Sefaz"
                            FontSize="16" Foreground="Gray" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15">
                        <!-- <TextBlock
                            Text="{Binding UltimaAtualizacao, StringFormat='Última atualização: {0}'}"
                            VerticalAlignment="Center" Foreground="Gray" FontSize="13"
                            FontStyle="Italic" /> -->

                        <Button Command="{Binding AtualizarManualCommand}"
                            IsEnabled="{Binding PodeAtualizar}"
                            Background="#E8EAF6" Foreground="#6200EE"
                            CornerRadius="20" Padding="15,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <icons:MaterialIcon Kind="CloudSync" Width="20" Height="20"
                                    VerticalAlignment="Center" />
                                <TextBlock Text="{Binding TextoBotaoAtualizar}" FontWeight="Bold"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border Background="#F8F9FA" CornerRadius="8" Padding="15" Margin="0,0,0,20"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Status da Sincronização com a Sefaz"
                                FontSize="14" FontWeight="Bold" Foreground="#333333" />

                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <ProgressBar IsIndeterminate="True" Width="150" Height="4"
                                    Margin="0,0,10,0"
                                    IsVisible="{Binding SyncStatus.EmExecucao}"
                                    Foreground="#2196F3" />
                                <TextBlock Text="{Binding SyncStatus.MensagemStatus}"
                                    FontSize="13" Foreground="#1976D2" FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20"
                            VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="Última Sincronização" FontSize="11"
                                    Foreground="#888888" />
                                <TextBlock
                                    Text="{Binding SyncStatus.UltimaSincronizacao, TargetNullValue='Nenhuma', StringFormat='dd/MM/yyyy HH:mm:ss'}"
                                    FontSize="13" FontWeight="Bold" Foreground="#333333" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Próxima Sincronização" FontSize="11"
                                    Foreground="#888888" />
                                <TextBlock
                                    Text="{Binding SyncStatus.ProximaSincronizacao, TargetNullValue='Calculando...', StringFormat='dd/MM/yyyy HH:mm:ss'}"
                                    FontSize="13" FontWeight="Bold" Foreground="#4CAF50" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*, 20, *, 20, *" Height="140" Margin="0,15,0,0">
                    <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="25"
                        BoxShadow="0 6 15 0 #1A000000">
                        <Grid ColumnDefinitions="Auto, *">
                            <Border Grid.Column="0" Background="#F3E5F5" CornerRadius="30"
                                Width="60" Height="60" VerticalAlignment="Center">
                                <icons:MaterialIcon Kind="CalendarMonth" Width="30" Height="30"
                                    Foreground="#6200EE" HorizontalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Documentos no Mês" FontSize="14" Foreground="Gray"
                                    FontWeight="SemiBold" />
                                <TextBlock Text="{Binding TotalDocumentosMes}" FontSize="36"
                                    FontWeight="Bold" Foreground="#6200EE" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="25"
                        BoxShadow="0 6 15 0 #1A000000">
                        <Grid ColumnDefinitions="Auto, *">
                            <Border Grid.Column="0" Background="#E8F5E9" CornerRadius="30"
                                Width="60" Height="60" VerticalAlignment="Center">
                                <icons:MaterialIcon Kind="CloudDownload" Width="30" Height="30"
                                    Foreground="#4CAF50" HorizontalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Novos Documentos (Hoje)" FontSize="14"
                                    Foreground="Gray" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding TotalDocumentosHoje}" FontSize="36"
                                    FontWeight="Bold" Foreground="#4CAF50" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="4" Background="White" CornerRadius="12" Padding="25"
                        BoxShadow="0 6 15 0 #1A000000">
                        <Grid ColumnDefinitions="Auto, *">
                            <Border Grid.Column="0" Background="#FFF8E1" CornerRadius="30"
                                Width="60" Height="60" VerticalAlignment="Center">
                                <icons:MaterialIcon Kind="ServerNetwork" Width="30" Height="30"
                                    Foreground="#FFA000" HorizontalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Status Serviços" FontSize="14" Foreground="Gray"
                                    FontWeight="SemiBold" />
                                <TextBlock Text="Ativo" FontSize="26" FontWeight="Bold"
                                    Foreground="#FFA000" Margin="0,5,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Border Background="White" CornerRadius="12" Padding="25"
                    BoxShadow="0 8 20 0 #1A000000" Margin="0,15,0,0">
                    <StackPanel Spacing="15">

                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Últimos Documentos Baixados" FontSize="20"
                                    FontWeight="SemiBold" Foreground="#333333" />
                                <TextBlock
                                    Text="Últimas 5 sincronizações realizadas pelo Serviço em segundo plano."
                                    FontSize="14" Foreground="Gray" />
                            </StackPanel>

                            <icons:MaterialIcon Grid.Column="1" Kind="History" Width="28"
                                Height="28" Foreground="#6200EE" VerticalAlignment="Center" />
                        </Grid>

                        <Separator Background="#EEEEEE" Margin="0,10" />

                        <DataGrid ItemsSource="{Binding DocumentosRecentes}"
                            AutoGenerateColumns="False" IsReadOnly="True"
                            CanUserResizeColumns="True" CanUserSortColumns="False" Height="280">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data Emissão"
                                    Binding="{Binding DataEmissao, StringFormat='dd/MM/yyyy HH:mm'}"
                                    Width="150" Foreground="#555555" FontSize="13" />

                                <DataGridTextColumn Header="NSU (Sefaz)" Binding="{Binding Nsu}"
                                    Width="150" FontWeight="Bold" />

                                <DataGridTextColumn Header="Tipo de Documento"
                                    Binding="{Binding SchemaDisplay}" Width="180"
                                    Foreground="#6200EE" />

                                <DataGridTemplateColumn Header="Chave de Acesso" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="dto:DocumentoDto">
                                            <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="10,0">
                                                <icons:MaterialIcon Kind="Barcode" Width="18"
                                                    Height="18" Foreground="Gray" />
                                                <TextBlock Text="{Binding ChaveAcesso}"
                                                    Margin="10,0,0,0" VerticalAlignment="Center"
                                                    FontStyle="Italic" Foreground="#555555" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Ciência?" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="dto:DocumentoDto">
                                            <icons:MaterialIcon Margin="10,0,0,0"
                                                HorizontalAlignment="Left"
                                                Kind="CheckCircle" Width="22" Height="22"
                                                Foreground="{Binding CienciaEnviada, Converter={StaticResource BoolToGreenRedConverter}}"
                                                ToolTip.Tip="{Binding CienciaEnviada, Converter={StaticResource BoolToCienciaConverter}}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>